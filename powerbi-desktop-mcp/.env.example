# Power BI Desktop MCP — Environment Configuration
# Copy to .env and fill in values on the Windows machine running Power BI Desktop.

# Port for the SSE HTTP server (Claude Code on Linux connects to this)
PBI_DESKTOP_PORT=7890

# Full path to PBIDesktop.exe (used by launch_powerbi_desktop tool)
# Typical location: C:\Program Files\Microsoft Power BI Desktop\bin\PBIDesktop.exe
PBI_DESKTOP_EXE=C:\Program Files\Microsoft Power BI Desktop\bin\PBIDesktop.exe

# Default directory for opening/saving PBIX and PBIR files
PBI_REPORTS_DIR=C:\Users\YourName\Documents\PowerBI
