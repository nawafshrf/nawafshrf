# Power BI MCP Extended — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Authentication mode ──────────────────────────────────────────────────────
# "service_principal"  → unattended automation (client credentials flow)
# "interactive"        → browser/device-code login (user-delegated permissions)
PBI_AUTH_MODE=service_principal

# ── Azure AD / Entra ID ──────────────────────────────────────────────────────
PBI_TENANT_ID=your-tenant-id
PBI_CLIENT_ID=your-app-client-id

# Required for service_principal auth only:
PBI_CLIENT_SECRET=your-client-secret

# ── Optional ─────────────────────────────────────────────────────────────────
# Default workspace (group) ID to use when none is provided in a tool call
PBI_DEFAULT_WORKSPACE_ID=

# Token cache file path for interactive auth (avoids re-login every run)
PBI_TOKEN_CACHE_PATH=.token_cache.json
